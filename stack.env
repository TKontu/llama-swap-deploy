# stack.env — placeholder for the Portainer stack environment.
#
# Leave this file value-free and set the variables in Portainer instead
# (Stacks → your stack → Environment variables). Portainer injects them for
# docker-compose substitution (${HF_TOKEN}, ${LLAMA_SWAP_IMAGE}) at deploy time.
#
# Expected variables:
#   HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx      # required — HuggingFace token
#   LLAMA_SWAP_IMAGE=ghcr.io/tkontu/llama-swap-deploy:latest   # optional — compose already defaults to this
#
# Do NOT commit real secrets here. The active .env is git-ignored.
