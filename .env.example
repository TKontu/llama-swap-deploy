# Copy to .env and fill in. Referenced by docker-compose.yml and passed into model cmds.
# In Portainer, set these as *stack environment variables* instead of a committed .env.

# HuggingFace token for gated/private repos (and faster downloads).
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Pre-built llama-swap image to run, built & pushed to GHCR by GitHub Actions.
# Compose already defaults to ghcr.io/tkontu/llama-swap-deploy:latest — set this only to
# override (e.g. pin a :<short-sha> tag from the Actions run summary, or use a fork).
LLAMA_SWAP_IMAGE=ghcr.io/tkontu/llama-swap-deploy:latest
