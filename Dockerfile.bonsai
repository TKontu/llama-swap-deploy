# PrismML llama.cpp fork image for Ternary-Bonsai-27B.
#
# Ternary-Bonsai needs PrismML's fork (Q2_0_g128 ternary + hybrid-attention CUDA
# kernels); mainline llama.cpp / vLLM cannot load it, and the HF repo is weights-only.
# We build llama-server from the fork's `prism` branch and ship it as an
# OpenAI-compatible server that llama-swap proxies like the vLLM models.
#
# Built & pushed to GHCR by .github/workflows/bonsai-image.yml.
# NOTE: Dockerfile inline comments are only valid on their own line (never after an
# instruction like ARG/ENV), so all comments here stand alone.

# ---- build stage -----------------------------------------------------------
FROM nvidia/cuda:12.6.2-devel-ubuntu22.04 AS build
# RTX 3090 = sm_86 (this box's two LLM cards).
ARG CUDA_ARCHS=86
ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
      git cmake ninja-build build-essential ca-certificates libcurl4-openssl-dev \
 && rm -rf /var/lib/apt/lists/*

RUN git clone --depth 1 -b prism https://github.com/PrismML-Eng/llama.cpp.git /src
WORKDIR /src

# The build box has no GPU/driver, so executables can't resolve CUDA driver-API
# symbols (cuMemCreate, cuDeviceGet, ...). Link against the CUDA driver STUB the
# devel image ships, exposed as libcuda.so.1 via LIBRARY_PATH. Build ONLY the
# server target (the fork's extra example binaries fail to link the stub and we
# don't need them). Cap parallelism by RAM to avoid nvcc OOM on smaller runners.
RUN ln -sf /usr/local/cuda/lib64/stubs/libcuda.so /usr/local/cuda/lib64/stubs/libcuda.so.1 \
 && export LIBRARY_PATH="/usr/local/cuda/lib64/stubs${LIBRARY_PATH:+:$LIBRARY_PATH}" \
 && cmake -B build -G Ninja \
      -DGGML_CUDA=ON \
      -DCMAKE_CUDA_ARCHITECTURES=${CUDA_ARCHS} \
      -DCMAKE_BUILD_TYPE=Release \
      -DLLAMA_BUILD_TESTS=OFF \
 && MEM_GB=$(( $(awk '/MemTotal/{print $2}' /proc/meminfo) / 1048576 )) \
 && JOBS=$([ "${MEM_GB:-0}" -lt 16 ] && echo 2 || echo 4) \
 && echo "building with -j${JOBS} (host ~${MEM_GB} GB RAM)" \
 && cmake --build build --target llama-server -j "${JOBS}"

# ---- runtime stage ---------------------------------------------------------
FROM nvidia/cuda:12.6.2-runtime-ubuntu22.04
ENV DEBIAN_FRONTEND=noninteractive
# python3 + gguf: read the DSpark drafter's block_size for --spec-draft-n-max.
# libcurl4/libgomp1: runtime deps of llama-server. curl: container health tooling.
RUN apt-get update && apt-get install -y --no-install-recommends \
      python3 python3-pip libgomp1 libcurl4 ca-certificates curl \
 && pip3 install --no-cache-dir gguf \
 && rm -rf /var/lib/apt/lists/*

# Copy the whole build output dir so the versioned .so SONAME symlinks
# (libggml-cuda.so -> .so.0 -> .so.0.13.1) are preserved for the runtime linker.
COPY --from=build /src/build/bin/ /opt/bonsai/bin/
ENV PATH="/opt/bonsai/bin:${PATH}"
ENV LD_LIBRARY_PATH="/opt/bonsai/bin"

COPY docker/bonsai-serve.sh /usr/local/bin/bonsai-serve.sh
RUN chmod +x /usr/local/bin/bonsai-serve.sh

# The entrypoint discovers the GGUF weights (mounted at /root/.cache/huggingface)
# and launches llama-server with vision + speculative + tool-calling flags.
ENTRYPOINT ["/usr/local/bin/bonsai-serve.sh"]
