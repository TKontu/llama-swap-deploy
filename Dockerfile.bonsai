# PrismML llama.cpp fork image for Ternary-Bonsai-27B.
#
# Ternary-Bonsai needs PrismML's fork (Q2_0_g128 ternary + hybrid-attention CUDA
# kernels); mainline llama.cpp / vLLM cannot load it. We build `llama-server` from
# the fork's `prism` branch and ship it as an OpenAI-compatible server that
# llama-swap proxies exactly like the vLLM models.
#
# Built & pushed to GHCR by .github/workflows/bonsai-image.yml. Referenced from
# config.yaml's "Ternary-Bonsai-27B" entry.

# ---- build stage -----------------------------------------------------------
FROM nvidia/cuda:12.6.2-devel-ubuntu22.04 AS build
ARG CUDA_ARCHS=86          # RTX 3090 = sm_86 (this box's two LLM cards)
ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
      git cmake ninja-build build-essential ca-certificates \
 && rm -rf /var/lib/apt/lists/*

RUN git clone --depth 1 -b prism https://github.com/PrismML-Eng/llama.cpp.git /src
WORKDIR /src

# Static link (BUILD_SHARED_LIBS=OFF) so the runtime image only needs the CUDA
# runtime libs, not llama.cpp's .so files. Build just the server target.
RUN cmake -B build -G Ninja \
      -DGGML_CUDA=ON \
      -DCMAKE_CUDA_ARCHITECTURES=${CUDA_ARCHS} \
      -DCMAKE_BUILD_TYPE=Release \
      -DBUILD_SHARED_LIBS=OFF \
      -DLLAMA_CURL=OFF \
 && MEM_GB=$(( $(awk '/MemTotal/{print $2}' /proc/meminfo) / 1048576 )) \
 && JOBS=$([ "${MEM_GB:-0}" -lt 16 ] && echo 2 || echo 4) \
 && echo "building with -j${JOBS} (host ~${MEM_GB} GB RAM)" \
 && cmake --build build --target llama-server -j "${JOBS}"

# ---- runtime stage ---------------------------------------------------------
FROM nvidia/cuda:12.6.2-runtime-ubuntu22.04
ENV DEBIAN_FRONTEND=noninteractive
# python3 + gguf: read the DSpark drafter's block_size for --spec-draft-n-max.
# curl: container-side health tooling. libgomp1: OpenMP runtime for ggml.
RUN apt-get update && apt-get install -y --no-install-recommends \
      python3 python3-pip libgomp1 ca-certificates curl \
 && pip3 install --no-cache-dir gguf \
 && rm -rf /var/lib/apt/lists/*

COPY --from=build /src/build/bin/llama-server /usr/local/bin/llama-server
COPY docker/bonsai-serve.sh /usr/local/bin/bonsai-serve.sh
RUN chmod +x /usr/local/bin/llama-server /usr/local/bin/bonsai-serve.sh

# The entrypoint discovers the GGUF weights (mounted at /root/.cache/huggingface)
# and launches llama-server with vision + speculative + tool-calling flags.
ENTRYPOINT ["/usr/local/bin/bonsai-serve.sh"]
